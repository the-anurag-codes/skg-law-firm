# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com → sign up → API Keys → Create
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The address that receives consultation form submissions
# Currently: skgambhir@hotmail.com (client's existing address)
# Recommended: contact@skgambhir.in (once domain email is set up)
CONTACT_EMAIL=skgambhir@hotmail.com

# The "From" address on outbound emails — must be verified in Resend
# Use a domain you own, e.g. noreply@skgambhir.in
FROM_EMAIL=noreply@skgambhir.in

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://skgambhir.in

# ─── Analytics (optional — Plausible recommended for law firms) ───────────────
# Uncomment and set domain once you add the Plausible script
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=skgambhir.in
